# 1. 깃(Git) 관련 파일 (용량이 크고 보안상 제외 필수)
.git
.gitignore

# 2. 파이썬 캐시 및 가상환경 (도커 안에서 다시 설치하므로 불필요)
__pycache__
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.env

# 3. 시스템 파일 (맥/윈도우 찌꺼기)
.DS_Store
Thumbs.db

# 4. 대용량 데이터 및 출력물 (사용자 요청)
# 루트 경로의 data 폴더만 무시합니다. (conf/data는 자동으로 포함됨)
data/
outputs/

# [중요] 만약 위에서 모든 data를 무시하려고 '**/data'라고 썼다면,
# 아래처럼 느낌표(!)를 붙여서 예외 처리를 해줘야 합니다.
# (지금은 위에서 'data/'라고만 썼으니 아래 줄은 없어도 되지만, 안전장치로 적어도 됩니다)
!conf/data/

# 5. 도커 빌드 파일 자체 (이미지 안에 들어갈 필요 없음)
.dockerignore